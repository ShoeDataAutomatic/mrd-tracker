# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# SQLite WAL/SHM sidecar files — these are transient and must never be
# committed on their own. A stale committed -wal paired with a freshly
# updated .db file caused "database disk image is malformed" errors.
*.db-wal
*.db-shm

# Environment
.env
.venv/
venv/

# Secrets — never commit these
credentials.json

# Logs
*.log

# Discovery output
primark_page.html
*_page.html

# Local OS
.DS_Store
Thumbs.db

# FUSE filesystem artifacts (created by Linux sandbox on NTFS mounts)
.fuse_hidden*

# Database backups (local only, large, not needed in git)
*.db.bak-*

# IDE
.vscode/
.idea/

# Note: mrd_tracker.db is intentionally NOT ignored.
# The database is committed to the repo so Railway always has
# the latest scraped data when it deploys.
